<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="340dp">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/popup_bg" />

    <!-- Content Wrapper -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/krona_one"
            android:text="Instructions"
            android:textColor="#3E211F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Instructions Text -->
        <TextView
            android:id="@+id/txtInstructions"
            android:layout_width="207dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:fontFamily="@font/krona_one"
            android:gravity="center"
            android:text="In the Donutify app, you pick two ingredients (icing or sprinkles) to create a donut, but you can’t repeat items or choose more than one sprinkle. Press Result to see your donut name and image, and Clear to start over."
            android:textColor="#3E211F"
            android:textSize="12sp" />

        <!-- Close Button -->
        <Button
            android:id="@+id/btnClose"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:backgroundTint="#3E211F"
            android:fontFamily="@font/krona_one"
            android:text="CLOSE"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>