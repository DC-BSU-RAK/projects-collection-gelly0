<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Ingredients Selection -->
    <ImageView
        android:id="@+id/topSelection"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="295dp"
        android:layout_marginEnd="75dp"
        android:scaleType="centerInside"
        android:src="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom Ingredients Selection -->
    <ImageView
        android:id="@+id/bottomSelection"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="75dp"
        android:scaleType="centerInside"
        android:src="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topSelection" />

    <!-- Results Button -->
    <Button
        android:id="@+id/btnResult"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginTop="35dp"
        android:layout_marginEnd="50dp"
        android:backgroundTint="#404040"
        android:fontFamily="@font/krona_one"
        android:text="RESULT"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottomSelection" />

    <!-- Clear Button -->
    <Button
        android:id="@+id/btnClear"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="170dp"
        android:backgroundTint="#404040"
        android:fontFamily="@font/krona_one"
        android:text="CLEAR"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Icing Buttons -->
    <ImageButton
        android:id="@+id/btnVanilla"
        android:layout_width="130dp"
        android:layout_height="100dp"
        android:layout_marginStart="5dp"
        android:layout_marginBottom="190dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/vanilla_icing"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnStrawberry"
        android:layout_width="130dp"
        android:layout_height="100dp"
        android:layout_marginBottom="190dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/strawberry_icing"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnChocolate"
        app:layout_constraintStart_toEndOf="@id/btnVanilla" />

    <ImageButton
        android:id="@+id/btnChocolate"
        android:layout_width="130dp"
        android:layout_height="100dp"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="190dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/chocolate_icing"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sprinkles -->
    <ImageButton
        android:id="@+id/btnChocoSprinkles"
        android:layout_width="130dp"
        android:layout_height="100dp"
        android:layout_marginStart="65dp"
        android:layout_marginBottom="70dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/choco_sprinkles"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnRainbowSprinkles"
        android:layout_width="130dp"
        android:layout_height="100dp"
        android:layout_marginEnd="65dp"
        android:layout_marginBottom="70dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/rainbow_sprinkles"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnInstruction"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/instructions"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>